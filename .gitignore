# macOS
.DS_Store

# Xcode
xcuserdata/
*.xcuserstate
DerivedData/
build/
*.xcresult

# SPM
.build/
.swiftpm/
Package.resolved

# Secrets — never commit credentials
.env
*.secrets

# Brand kit working files (extracted zip; curated assets are committed)
Brand/_kit-download/

# Claude Code assets — ignore everything under .claude by default (local
# settings, agent worktrees, caches, history, todos), then re-include only the
# shareable, version-controlled project assets.
.claude/*
!.claude/README.md
!.claude/agents/
!.claude/skills/
